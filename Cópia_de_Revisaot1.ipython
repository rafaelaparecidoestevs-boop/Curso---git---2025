      ],
      "source": [
        "#R1 - Variaveis, tipos, saida e entrada\n",
        "nome = input(\"Digite seu nome: \")\n",
        "idade = int(input(\"Digite sua idade: \"))\n",
        "altura = float(input(\"Digite sua altura: \"))\n",
        "print(f\"Olá, {nome}!\")\n",
        "print(f\"Você tem {idade} anos e mede {altura:.2f}\")\n",
        "print(type(nome))\n",
        "print(type(idade))\n",
        "print(type(altura))"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "#R2 - Operadores aritméticos e comparação\n",
        "num1 = float(input(\"Digite o primeiro número: \"))\n",
        "num2 = float(input(\"Digite o segundo número: \"))\n",
        "print(f\"Soma: {num1 + num2}\")\n",
        "print(f\"Subtração: {num1 - num2}\")\n",
        "print(f\"Multiplicação: {num1 * num2}\")\n",
        "print(f\"Divisão: {num1 / num2}\")\n",
        "print(num1 > num2) # True se for n1 > n2\n",
        "print(num1 < num2) # True se for n1 < n2\n",
        "print(num1 >= num2) # True se n1 >= n2\n",
        "print(num1 <= num2) # True se n1 <= n2\n",
        "print(num1 == num2) # True se n1 == n2"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "collapsed": true,
        "id": "vz81WP-7iuZe",
        "outputId": "3287cb2e-44d3-4148-b319-83f70671d4e3"
