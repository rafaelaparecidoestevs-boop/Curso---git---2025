    {
      "cell_type": "code",
      "source": [
        "#R3 -Condicional if, elil, else\n",
        "nota1 = float(input(\"Digite a primeira nota: \"))\n",
        "nota2 = float(input(\"Digite a segunda nota: \"))\n",
        "media = (nota1 + nota2) / 2\n",
        "print(f\"Média: {media:.2f}\")\n",
        "if media >= 7:\n",
        "  print(\"Aprovado\")\n",
        "elif media >=5:\n",
        "  print(\"Recuperação\")\n",
        "else:\n",
        "  print(\"Reprovado\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "collapsed": true,
